---
import Layout from '../layouts/Layout.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';
import StepsForm from '../components/StepsForm.astro';
import communes from '../data/communes.json';

const title = "Réfection de Toiture en Loire-Atlantique (44) — Couvreur Ardoise & Zinc | Devis 2026";
const description = "Spécialiste de la réfection de toiture ardoise d'Angers et zinc en Loire-Atlantique. Étanchéité garantie face au climat breton. Recevez 3 devis de couvreurs RGE.";

// Select the top 12 cities for homepage list
const popularCities = communes.slice(0, 12);
---

<Layout title={title} description={description}>
  <SchemaMarkup
    slot="head"
    pageUrl={Astro.url.href}
    pageTitle={title}
    pageDescription={description}
    faqItems={[
      {
        q: "Quel est le prix moyen au m² d'un couvreur en Loire-Atlantique en 2026 ?",
        a: "Le tarif d'un couvreur en Loire-Atlantique varie selon le matériau choisi : entre 120€ et 190€ le m² TTC pour de l'ardoise naturelle d'Angers posée sur crochet inox (pose et dépose comprises), et de 140€ à 210€ le m² pour du zinc joint debout. L'ardoise synthétique fibro-ciment oscille entre 70€ et 110€ le m²."
      },
      {
        q: "Pourquoi le climat de Loire-Atlantique exige-t-il des fixations spécifiques ?",
        a: "La Loire-Atlantique subit les vents d'ouest et les embruns côtiers (corrosion saline). Sur le littoral (Pornic, Saint-Nazaire, Guérande), l'usage de crochets en acier inoxydable de qualité marine (inox 316L) est obligatoire pour fixer les ardoises et éviter la rouille sous l'effet du sel."
      },
      {
        q: "Quelles sont les aides pour l'isolation de toiture à Nantes et alentours ?",
        a: "En confiant l'isolation de votre toiture (sarking ou combles) à un artisan certifié RGE du 44, vous bénéficiez de MaPrimeRénov', des primes CEE de Loire-Atlantique et d'une TVA réduite à 5,5%."
      }
    ]}
  />

  <!-- Hero Section -->
  <section class="hero">
    <!-- Suble Rain Drops Animation Container -->
    <div class="rain-container" id="rain-overlay"></div>
    <div class="container" style="position: relative; z-index: 2;">
      <div class="two-column-layout">
        <!-- Hero Left Info -->
        <div>
          <div class="alert-pill">
            <div class="alert-pulse-icon"></div>
            <span>Spécialiste ardoise &amp; zinc — résistance à l'humidité</span>
          </div>
          <h1>
            Réfection de Toiture Ardoise &amp; Zinc en Loire-Atlantique (44)
          </h1>
          <p>
            Pluie océanique fréquente, vents marins corrosifs et tempêtes hivernales d'ouest... Protégez durablement votre patrimoine breton et ligérien. Obtenez 3 devis d'artisans couvreurs RGE qualifiés assurés en décennale.
          </p>
          
          <div style="display: flex; gap: 20px; margin-top: 10px; flex-wrap: wrap;">
            <div style="background: rgba(255, 255, 255, 0.08); border: 1.5px solid rgba(255, 255, 255, 0.15); padding: 12px 20px; border-radius: var(--radius-sm);">
              <span style="font-size: 20px; margin-right: 8px;">🛡️</span>
              <strong style="color: white; font-size: 14.5px;">Garantie Décennale 10 ans</strong>
            </div>
            <div style="background: rgba(255, 255, 255, 0.08); border: 1.5px solid rgba(255, 255, 255, 0.15); padding: 12px 20px; border-radius: var(--radius-sm);">
              <span style="font-size: 20px; margin-right: 8px;">💎</span>
              <strong style="color: white; font-size: 14.5px;">Ardoises d'Angers &amp; Zinc Joint Debout</strong>
            </div>
          </div>
        </div>

        <!-- Hero Right Form -->
        <div>
          <StepsForm />
        </div>
      </div>
    </div>
  </section>

  <!-- Regional Context Section -->
  <section style="padding: 75px 0; background-color: var(--card-bg);">
    <div class="container">
      <div style="text-align: center; max-width: 800px; margin: 0 auto 50px;">
        <span class="badge-pill" style="margin-bottom: 15px;">🌧️ Faire Face au Climat Océanique</span>
        <h2 style="font-family: var(--font-heading); font-size: 32px; font-weight: 900; color: var(--primary); margin-bottom: 15px;">
          Pourquoi les toitures du 44 exigent une étanchéité renforcée ?
        </h2>
        <p style="font-size: 16.5px; color: var(--text-muted); line-height: 1.6;">
          Le département de la Loire-Atlantique associe l'agglomération nantaise humide à une façade maritime soumise aux tempêtes d'ouest et à la corrosion saline.
        </p>
      </div>

      <div class="two-column-layout" style="align-items: stretch; gap: 40px;">
        <!-- Left: Weather challenges cards -->
        <div style="display: flex; flex-direction: column; gap: 20px;">
          <div class="card" style="border-left: 4px solid var(--secondary); border-top: none; display: flex; gap: 15px; padding: 20px; align-items: start;">
            <div style="font-size: 28px; line-height: 1;">🌬️</div>
            <div>
              <h3 style="font-family: var(--font-heading); font-size: 17px; font-weight: 800; color: var(--primary); margin-bottom: 6px;">Vents Forts du Littoral</h3>
              <p style="font-size: 13.5px; color: var(--text-muted); line-height: 1.5; margin: 0;">
                Sur la côte, les coups de vent d'ouest soufflent l'eau de pluie sous les ardoises. Les couvertures doivent être posées avec un écran HPV résistant et des clouages de sécurité renforcés.
              </p>
            </div>
          </div>

          <div class="card" style="border-left: 4px solid var(--secondary); border-top: none; display: flex; gap: 15px; padding: 20px; align-items: start;">
            <div style="font-size: 28px; line-height: 1;">🧂</div>
            <div>
              <h3 style="font-family: var(--font-heading); font-size: 17px; font-weight: 800; color: var(--primary); margin-bottom: 6px;">Corrosion Saline &amp; Embruns</h3>
              <p style="font-size: 13.5px; color: var(--text-muted); line-height: 1.5; margin: 0;">
                L'air marin corrode le fer et les métaux de toiture ordinaires. L'utilisation de crochets en acier inoxydable de qualité marine (inox 316L) et de cheneaux en zinc de fort calibre est indispensable.
              </p>
            </div>
          </div>

          <div class="card" style="border-left: 4px solid var(--secondary); border-top: none; display: flex; gap: 15px; padding: 20px; align-items: start;">
            <div style="font-size: 28px; line-height: 1;">🌧️</div>
            <div>
              <h3 style="font-family: var(--font-heading); font-size: 17px; font-weight: 800; color: var(--primary); margin-bottom: 6px;">Humidité &amp; Pluie Stagnante</h3>
              <p style="font-size: 13.5px; color: var(--text-muted); line-height: 1.5; margin: 0;">
                Avec plus de 820 mm de pluie par an, le crachin océanique favorise la mousse et les lichens noirs, rendant les ardoises poreuses et provoquant des fuites lentes sous les solins.
              </p>
            </div>
          </div>
        </div>

        <!-- Right: Illustrative image -->
        <div style="border-radius: var(--radius-md); overflow: hidden; border: 2px solid var(--border-color); box-shadow: var(--shadow-sm); display: flex; flex-direction: column;">
          <img 
            src="/images/hero-toiture-loire-atlantique.png" 
            alt="Maison nantaise traditionnelle en tuffeau avec toiture ardoise d'Angers sous un ciel atlantique" 
            style="width: 100%; height: 100%; object-fit: cover; min-height: 350px;" 
          />
          <div style="padding: 12px 18px; background: white; border-top: 1.5px solid var(--border-color); font-size: 12.5px; color: var(--text-muted); font-family: var(--font-mono);">
            🏡 Maison nantaise : murs en tuffeau et couverture en ardoises naturelles d'Angers posées au crochet.
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Materials Guide Section -->
  <section style="padding: 75px 0; background-color: #F1F5F9; border-top: 1.5px solid var(--border-color); border-bottom: 1.5px solid var(--border-color);">
    <div class="container">
      <div style="text-align: center; max-width: 800px; margin: 0 auto 50px;">
        <span class="badge-pill" style="margin-bottom: 15px;">💎 Matériaux &amp; Identité</span>
        <h2 style="font-family: var(--font-heading); font-size: 32px; font-weight: 900; color: var(--primary); margin-bottom: 15px;">
          Quel matériau de toiture choisir en Loire-Atlantique ?
        </h2>
        <p style="font-size: 16px; color: var(--text-muted);">
          Le choix des matériaux s'adapte à l'histoire locale, aux règles PLU et au niveau d'exposition face à l'océan.
        </p>
      </div>

      <div class="grid-3" style="align-items: stretch;">
        <!-- Ardoise Naturelle -->
        <div style="background: white; border: 1.5px solid var(--border-color); border-radius: var(--radius-md); box-shadow: var(--shadow-sm); padding: 30px; display: flex; flex-direction: column;">
          <div style="font-size: 36px; margin-bottom: 15px;">💎</div>
          <h3 style="font-family: var(--font-heading); font-size: 19px; font-weight: 800; color: var(--primary); margin-bottom: 10px;">L'Ardoise Naturelle (d'Angers)</h3>
          <p style="font-size: 14px; color: var(--text-muted); line-height: 1.6; margin-bottom: 20px; flex-grow: 1;">
            Le choix historique premium pour les maisons en tuffeau et pavillons de caractère. Posée sur crochets inox, l'ardoise naturelle d'Angers offre une longévité de 80 à 100 ans.
          </p>
          <ul style="padding-left: 20px; font-size: 13px; color: var(--text); display: flex; flex-direction: column; gap: 8px; margin: 0;">
            <li><strong>Durée de vie :</strong> 80 ans +</li>
            <li><strong>Esthétique :</strong> Bleue-noire noble et brillante</li>
            <li><strong>Vent :</strong> Excellente résistance mécanique</li>
          </ul>
        </div>

        <!-- Zinc Joint Debout -->
        <div style="background: white; border: 1.5px solid var(--border-color); border-radius: var(--radius-md); box-shadow: var(--shadow-sm); padding: 30px; display: flex; flex-direction: column;">
          <div style="font-size: 36px; margin-bottom: 15px;">⚡</div>
          <h3 style="font-family: var(--font-heading); font-size: 19px; font-weight: 800; color: var(--primary); margin-bottom: 10px;">Le Zinc en Joint Debout</h3>
          <p style="font-size: 14px; color: var(--text-muted); line-height: 1.6; margin-bottom: 20px; flex-grow: 1;">
            L'identité des immeubles historiques nantais. Parfaitement malléable et 100% étanche, le zinc convient idéalement aux toitures à faible pente et à l'architecture contemporaine.
          </p>
          <ul style="padding-left: 20px; font-size: 13px; color: var(--text); display: flex; flex-direction: column; gap: 8px; margin: 0;">
            <li><strong>Durée de vie :</strong> 50 à 70 ans</li>
            <li><strong>Étanchéité :</strong> Totale (soudures continues)</li>
            <li><strong>Usage :</strong> Faibles pentes et lucarnes</li>
          </ul>
        </div>

        <!-- Tuiles Canal & Romane -->
        <div style="background: white; border: 1.5px solid var(--border-color); border-radius: var(--radius-md); box-shadow: var(--shadow-sm); padding: 30px; display: flex; flex-direction: column;">
          <div style="font-size: 36px; margin-bottom: 15px;">🏡</div>
          <h3 style="font-family: var(--font-heading); font-size: 19px; font-weight: 800; color: var(--primary); margin-bottom: 10px;">La Tuile Canal (Sud de la Loire)</h3>
          <p style="font-size: 14px; color: var(--text-muted); line-height: 1.6; margin-bottom: 20px; flex-grow: 1;">
            Typique du Vignoble Nantais, du Pays de Retz et des limites vendéennes. Offre des teintes chaleureuses ocre rouge adaptées aux maisons rurales de plaine.
          </p>
          <ul style="padding-left: 20px; font-size: 13px; color: var(--text); display: flex; flex-direction: column; gap: 8px; margin: 0;">
            <li><strong>Durée de vie :</strong> 40 à 60 ans</li>
            <li><strong>Style :</strong> Méditerranéen, ocre et terre cuite</li>
            <li><strong>Pente :</strong> Adaptée aux faibles inclinaisons</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Pluviomètre & Diagnostic Humidité Simulator -->
  <section style="padding: 75px 0; background-color: var(--card-bg);">
    <div class="container" style="max-width: 800px;">
      <div style="text-align: center; margin-bottom: 40px;">
        <span class="badge-pill" style="margin-bottom: 15px;">🌧️ Simulateur Humidité &amp; Infiltration</span>
        <h2 style="font-family: var(--font-heading); font-size: 32px; font-weight: 900; color: var(--primary); margin-bottom: 15px;">
          Calculer l'indice de risque d'infiltration de mon toit
        </h2>
        <p style="font-size: 16px; color: var(--text-muted);">
          Estimez le niveau d'usure et la sensibilité de votre couverture face au climat humide de Loire-Atlantique.
        </p>
      </div>

      <div style="background: white; border: 2px solid var(--border-color); border-radius: var(--radius-md); padding: 35px; box-shadow: var(--shadow-ocean);">
        <div style="display: flex; flex-direction: column; gap: 20px;">
          <!-- Field 1: Local zone selection -->
          <div class="form-group">
            <label style="font-family: var(--font-heading); font-weight: bold; font-size: 15.5px;">Secteur géographique en Loire-Atlantique :</label>
            <select id="simulator-region" class="form-control" style="width: 100%; cursor: pointer;">
              <option value="820-1.0">Nantes Métropole (Pluie régulière, humidité stagnante)</option>
              <option value="780-1.3">Façade Littorale / Pornic (Vents d'ouest et embruns salins)</option>
              <option value="750-0.9">Vignoble / Pays de Retz (Averses intermittentes)</option>
              <option value="850-1.1">Nord-Loire / Brière (Humidité de sous-bois et gel hivernal)</option>
            </select>
          </div>

          <!-- Field 2: Materials -->
          <div class="form-group">
            <label style="font-family: var(--font-heading); font-weight: bold; font-size: 15.5px;">Matériau actuel de couverture :</label>
            <select id="simulator-material" class="form-control" style="width: 100%; cursor: pointer;">
              <option value="1.0">Ardoise naturelle (Angers ou Espagne A1)</option>
              <option value="1.5">Ardoise synthétique (Fibro-ciment)</option>
              <option value="0.8">Toiture Zinc</option>
              <option value="1.3">Tuile Canal ou Romane</option>
            </select>
          </div>

          <!-- Field 3: Age slider -->
          <div class="form-group">
            <label style="font-family: var(--font-heading); font-weight: bold; font-size: 15.5px;">Âge de la toiture :</label>
            <div style="display: flex; justify-content: space-between; font-weight: bold; margin-bottom: 8px;">
              <span id="simulator-age-val" style="color: var(--accent); font-family: var(--font-mono);">25 ans</span>
            </div>
            <input type="range" id="simulator-age" min="1" max="80" step="1" value="25" style="width: 100%; accent-color: var(--accent); cursor: pointer;" />
          </div>

          <!-- Divider -->
          <hr style="border: 0; border-top: 1.5px solid var(--border-color); margin: 10px 0;" />

          <!-- Output Box -->
          <div style="background: var(--primary-light); border: 2.5px dashed var(--border-color); padding: 25px; border-radius: var(--radius-sm); display: flex; flex-direction: column; align-items: center; gap: 10px;">
            <div style="font-size: 13.5px; color: var(--primary); font-weight: bold; text-transform: uppercase; letter-spacing: 0.5px;">Indice de Risque d'Infiltration / Porosité :</div>
            <div style="font-size: 32px; font-weight: 900; color: var(--primary); font-family: var(--font-mono);" id="simulator-result">
              35 %
            </div>
            <p style="font-size: 12.5px; color: var(--text-muted); text-align: center; margin: 0; line-height: 1.6;" id="simulator-advice">
              Toiture dans sa période de maturité. Un traitement hydrofuge de surface est conseillé pour refermer les pores du support.
            </p>
          </div>

          <div style="text-align: center; margin-top: 10px;">
            <a href="#devis" class="btn-primary" style="display: inline-block; color: #0f172a;">📋 Demander un Diagnostic Gratuit de mon Toit &rarr;</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Popular Cities Link Directory -->
  <section style="padding: 75px 0; background-color: #F8FAFC; border-top: 1.5px solid var(--border-color); border-bottom: 1.5px solid var(--border-color);">
    <div class="container">
      <div style="text-align: center; max-width: 800px; margin: 0 auto 40px;">
        <span class="badge-pill" style="margin-bottom: 15px;">🗺️ Interventions locales</span>
        <h2 style="font-family: var(--font-heading); font-size: 32px; font-weight: 900; color: var(--primary);">
          Villes principales d'intervention en Loire-Atlantique
        </h2>
        <p style="font-size: 16px; color: var(--text-muted); margin-top: 10px;">
          Retrouvez nos couvreurs partenaires actifs sur votre secteur du 44.
        </p>
      </div>

      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 20px;">
        {popularCities.map((c) => (
          <div style="background: white; border: 1.5px solid var(--border-color); border-radius: var(--radius-sm); padding: 20px; box-shadow: var(--shadow-sm); display: flex; flex-direction: column; justify-content: space-between;">
            <h3 style="font-family: var(--font-heading); font-size: 18px; font-weight: 800; color: var(--text); margin-bottom: 12px;">
              🏢 Couvreur {c.nom} ({c.codePostal})
            </h3>
            <div style="display: flex; flex-direction: column; gap: 6px; font-size: 13px;">
              <a href={`/refection-toiture-${c.slug}/`} style="color: var(--accent); font-weight: bold;">🔨 Toiture &amp; Couverture &rarr;</a>
              <a href={`/demoussage-toiture-${c.slug}/`} style="color: var(--accent); font-weight: bold;">🧼 Nettoyage &amp; Démoussage &rarr;</a>
              <a href={`/couvreur-ardoisier-${c.slug}/`} style="color: var(--accent); font-weight: bold;">👤 Couvreur Ardoisier RGE &rarr;</a>
            </div>
          </div>
        ))}
      </div>
      
      <div style="text-align: center; margin-top: 40px;">
        <a href="/communes/" class="btn-secondary" style="display: inline-block;">🗺️ Voir toutes les communes de Loire-Atlantique &rarr;</a>
      </div>
    </div>
  </section>

  <!-- GUIDES — Internal Linking -->
  <section style="padding: 75px 0; background-color: var(--card-bg); border-top: 1.5px solid var(--border-color);">
    <div class="container">
      <div style="text-align: center; max-width: 800px; margin: 0 auto 40px;">
        <span class="badge-pill" style="margin-bottom: 15px;">📚 Nos Guides Experts</span>
        <h2 style="font-family: var(--font-heading); font-size: 32px; font-weight: 900; color: var(--primary);">
          Tout savoir sur les toitures en Loire-Atlantique
        </h2>
        <p style="font-size: 16px; color: var(--text-muted); margin-top: 10px;">
          Rédigés par des couvreurs qualifiés, nos guides répondent aux questions des propriétaires du 44 sur le budget, l'ardoise d'Angers et les tempêtes.
        </p>
      </div>

      <div class="grid-3" style="gap: 20px;">
        <a href="/guides/prix-toiture-loire-atlantique-2026-ardoise-zinc-tuile/" style="background: white; border: 1.5px solid var(--border-color); border-radius: var(--radius-sm); padding: 22px; text-decoration: none; display: block; box-shadow: var(--shadow-sm); transition: var(--transition);">
          <div style="font-size: 26px; margin-bottom: 10px;">🧮</div>
          <h3 style="font-family: var(--font-heading); font-size: 16px; font-weight: 800; color: var(--primary); margin-bottom: 8px;">Tarifs Toiture 44 en 2026</h3>
          <p style="font-size: 13px; color: var(--text-muted); line-height: 1.6; margin: 0;">Toutes les fourchettes de prix par type de travaux et par zone (Nantes centre, côte de Jade, Pays de Retz).</p>
        </a>

        <a href="/guides/toiture-pluie-atlantique-etancheite-climat-44/" style="background: white; border: 1.5px solid var(--border-color); border-radius: var(--radius-sm); padding: 22px; text-decoration: none; display: block; box-shadow: var(--shadow-sm); transition: var(--transition);">
          <div style="font-size: 26px; margin-bottom: 10px;">🌧️</div>
          <h3 style="font-family: var(--font-heading); font-size: 16px; font-weight: 800; color: var(--primary); margin-bottom: 8px;">Étanchéité &amp; Pluie Atlantique</h3>
          <p style="font-size: 13px; color: var(--text-muted); line-height: 1.6; margin: 0;">Comprendre l'impact des précipitations côtières et l'importance des sous-toitures de classe R2.</p>
        </a>

        <a href="/guides/ardoise-naturelle-angers-choix-toitures-nantaises/" style="background: white; border: 1.5px solid var(--border-color); border-radius: var(--radius-sm); padding: 22px; text-decoration: none; display: block; box-shadow: var(--shadow-sm); transition: var(--transition);">
          <div style="font-size: 26px; margin-bottom: 10px;">💎</div>
          <h3 style="font-family: var(--font-heading); font-size: 16px; font-weight: 800; color: var(--primary); margin-bottom: 8px;">L'Ardoise Naturelle d'Angers</h3>
          <p style="font-size: 13px; color: var(--text-muted); line-height: 1.6; margin: 0;">Pourquoi l'ardoise d'Angers reste le matériau traditionnel d'excellence sur les toits nantais.</p>
        </a>
      </div>

      <div style="text-align: center; margin-top: 35px;">
        <a href="/communes/" class="btn-secondary" style="display: inline-block;">📚 Consulter l'ensemble de nos guides toiture &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Interactive Simulator Script & Rain drops generator -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const regionSelect = document.getElementById('simulator-region') as HTMLSelectElement;
      const materialSelect = document.getElementById('simulator-material') as HTMLSelectElement;
      const ageSlider = document.getElementById('simulator-age') as HTMLInputElement;
      const ageVal = document.getElementById('simulator-age-val');
      const resultDiv = document.getElementById('simulator-result');
      const adviceP = document.getElementById('simulator-advice');

      const calculate = () => {
        if (!regionSelect || !materialSelect || !ageSlider || !resultDiv || !adviceP) return;

        const [pluvio, regionFactor] = regionSelect.value.split('-').map(Number);
        const matFactor = Number(materialSelect.value);
        const age = Number(ageSlider.value);

        if (ageVal) ageVal.textContent = `${age} ${age > 1 ? 'ans' : 'an'}`;

        // Base risk calculation: increases with age and climate factors
        // Age increases risk non-linearly:
        // age < 15: low risk base
        // age 15-40: moderate base
        // age > 40: high base
        let ageRisk = 5;
        if (age >= 15 && age < 40) {
          ageRisk = 5 + (age - 15) * 1.5;
        } else if (age >= 40) {
          ageRisk = 42 + (age - 40) * 1.25;
        }

        // Multiply by material factor and region factor
        let finalRisk = Math.round(ageRisk * matFactor * regionFactor);
        finalRisk = Math.min(100, Math.max(0, finalRisk));

        resultDiv.textContent = `${finalRisk} %`;

        // Render advice
        if (finalRisk >= 75) {
          adviceP.innerHTML = `<strong>⚠️ Risque Élevé :</strong> Toiture vieillissante exposée aux vents et pluies du 44. Risque fort de porosité d'ardoise et d'oxydation de crochets. Une réfection complète ou une intervention curative urgente est fortement recommandée.`;
        } else if (finalRisk >= 40) {
          adviceP.innerHTML = `<strong>⚠️ Risque Modéré :</strong> Présence probable de mousses gorgées d'eau retenant l'humidité. Un nettoyage doux basse pression suivi d'un traitement algicide et d'un hydrofuge de surface est conseillé pour imperméabiliser le support.`;
        } else {
          adviceP.innerHTML = `<strong>✓ Risque Faible :</strong> Couverture récente ou très résistante. Un contrôle de routine des gouttières en zinc et de l'état des rives après tempête est suffisant pour maintenir l'étanchéité.`;
        }
      };

      // Listeners
      regionSelect.addEventListener('change', calculate);
      materialSelect.addEventListener('change', calculate);
      ageSlider.addEventListener('input', calculate);

      // Initial run
      calculate();
    });

    // Subtle Rain Drops Generator
    const rainOverlay = document.getElementById('rain-overlay');
    if (rainOverlay) {
      const dropCount = 40;
      for (let i = 0; i < dropCount; i++) {
        const drop = document.createElement('div');
        drop.classList.add('raindrop');
        
        // Random dimensions and speed
        const left = Math.random() * 100;
        const duration = Math.random() * 1.5 + 0.8; // Fast fall
        const delay = Math.random() * 2;
        const height = Math.random() * 15 + 10;
        
        drop.style.left = `${left}%`;
        drop.style.height = `${height}px`;
        drop.style.animationDuration = `${duration}s`;
        drop.style.animationDelay = `-${delay}s`;
        
        rainOverlay.appendChild(drop);
      }
    }
  </script>
</Layout>
