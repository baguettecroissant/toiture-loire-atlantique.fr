---
import Layout from '../layouts/Layout.astro';
import StepsForm from '../components/StepsForm.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const title = "Demande de Devis Toiture Gratuit — Loire-Atlantique (44) | Rénovation & Entretien";
const description = "Estimez le prix de vos chantiers de couverture en ardoise, zinc ou tuiles. Obtenez 3 devis d'artisans RGE certifiés en Loire-Atlantique.";

const breadcrumbItems = [
  { label: "Accueil", href: "/" },
  { label: "Demande de Devis Toiture" }
];
---

<Layout title={title} description={description}>
  <Breadcrumb items={breadcrumbItems} />

  <section style="padding: 50px 0 80px; background: linear-gradient(135deg, rgba(15,23,42,0.04) 0%, rgba(132,204,22,0.02) 100%);">
    <div class="container" style="max-width: 800px;">
      <div style="text-align: center; margin-bottom: 40px;">
        <span class="badge-pill" style="margin-bottom: 15px;">⏱️ Simulation en 2 minutes</span>
        <h1 style="font-family: var(--font-heading); font-size: 36px; font-weight: 900; color: var(--primary); margin-bottom: 15px;">
          Votre Devis Toiture &amp; Couverture en Loire-Atlantique
        </h1>
        <p style="font-size: 16.5px; color: var(--text-muted); line-height: 1.6;">
          Remplissez notre formulaire pour chiffrer vos travaux. Votre projet sera transmis à des couvreurs qualifiés RGE du 44 assurés en garantie décennale.
        </p>
      </div>

      <div>
        <StepsForm />
      </div>

      <div class="grid-3" style="margin-top: 60px; text-align: center; gap: 20px;">
        <div style="background: white; border: 1.5px solid var(--border-color); padding: 25px; border-radius: var(--radius-sm); box-shadow: var(--shadow-sm);">
          <div style="font-size: 28px; margin-bottom: 10px;">📋</div>
          <h3 style="font-family: var(--font-heading); font-size: 16.5px; font-weight: 800; color: var(--primary); margin-bottom: 8px;">1. Décrivez votre projet</h3>
          <p style="font-size: 13px; color: var(--text-muted); line-height: 1.5; margin: 0;">Spécifiez le type de couverture (ardoise naturelle d'Angers, zinc, tuiles), la surface et l'adresse du chantier.</p>
        </div>
        
        <div style="background: white; border: 1.5px solid var(--border-color); padding: 25px; border-radius: var(--radius-sm); box-shadow: var(--shadow-sm);">
          <div style="font-size: 28px; margin-bottom: 10px;">📞</div>
          <h3 style="font-family: var(--font-heading); font-size: 16.5px; font-weight: 800; color: var(--primary); margin-bottom: 8px;">2. Validation Technique</h3>
          <p style="font-size: 13px; color: var(--text-muted); line-height: 1.5; margin: 0;">Un conseiller local étudie vos besoins par téléphone pour estimer votre budget et les aides de Nantes Métropole ou CEE.</p>
        </div>

        <div style="background: white; border: 1.5px solid var(--border-color); padding: 25px; border-radius: var(--radius-sm); box-shadow: var(--shadow-sm);">
          <div style="font-size: 28px; margin-bottom: 10px;">🤝</div>
          <h3 style="font-family: var(--font-heading); font-size: 16.5px; font-weight: 800; color: var(--primary); margin-bottom: 8px;">3. Comparez &amp; Choisissez</h3>
          <p style="font-size: 13px; color: var(--text-muted); line-height: 1.5; margin: 0;">Recevez gratuitement jusqu'à 3 offres détaillées de couvreurs locaux du 44, sans aucun engagement.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
